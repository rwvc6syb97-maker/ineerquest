# InnerQuest 环境配置样例 —— test（测试/CI 环境）
# 敏感项标注 [blocked]，需人工/CI Secret 注入真实值

NODE_ENV=test
PORT=3000

# MySQL（测试库，主机名按环境覆盖）
DATABASE_URL="mysql://innerquest:CHANGE_ME@mysql-test:3306/innerquest_test?connection_limit=10"  # [blocked] 密码

# 缓存/限流/配额/锁已改用 MySQL(cache_kv / cache_zset)，无需 Redis/MongoDB
CLICKHOUSE_URL="http://clickhouse-test:8123"
CLICKHOUSE_USER="default"
CLICKHOUSE_PASSWORD="CHANGE_ME"   # [blocked]
CLICKHOUSE_DB="innerquest_ops_test"

# OSS —— [blocked]
OSS_REGION="oss-cn-hangzhou"
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
OSS_BUCKET="innerquest-test"

# JWT —— [blocked] CI Secret 注入
JWT_SECRET="CHANGE_ME"
JWT_ACCESS_TTL="2h"
JWT_REFRESH_TTL="30d"

# LLM / 微信支付 —— [blocked]（测试环境建议走 mock/sandbox）
LLM_API_KEY=""
WECHAT_PAY_MCHID=""
WECHAT_PAY_API_KEY=""
WECHAT_PAY_CERT_SERIAL=""