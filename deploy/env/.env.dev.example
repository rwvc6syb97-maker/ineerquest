# InnerQuest 环境配置样例 —— dev（本地开发）
# 用法：cp deploy/env/.env.dev.example .env
# 敏感项标注 [blocked]，需人工补齐真实值；本地默认对接 docker-compose 内服务

# 服务
NODE_ENV=development
PORT=3000

# MySQL 8（docker-compose 内服务名 mysql）
MYSQL_ROOT_PASSWORD=innerquest
MYSQL_DATABASE=innerquest
DATABASE_URL="mysql://root:innerquest@mysql:3306/innerquest?connection_limit=10"

# Redis
REDIS_URL="redis://redis:6379/0"

# MongoDB
MONGODB_URI="mongodb://mongo:27017"
MONGODB_DB="innerquest"

# ClickHouse
CLICKHOUSE_URL="http://clickhouse:8123"
CLICKHOUSE_USER="default"
CLICKHOUSE_PASSWORD=""
CLICKHOUSE_DB="innerquest_ops"

# 阿里云 OSS —— [blocked] 需人工补齐
OSS_REGION="oss-cn-hangzhou"
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
OSS_BUCKET="innerquest"

# JWT —— dev 可用弱密钥，生产必须替换
JWT_SECRET="dev-secret-not-for-prod"
JWT_ACCESS_TTL="2h"
JWT_REFRESH_TTL="30d"

# LLM 网关 —— [blocked] 需人工补齐
LLM_API_KEY=""
# 微信支付 —— [blocked] 需人工补齐
WECHAT_PAY_MCHID=""
WECHAT_PAY_API_KEY=""
WECHAT_PAY_CERT_SERIAL=""