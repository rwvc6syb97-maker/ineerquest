{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "api": {
      "name": "innerquest-api",
      "build": {
        "builder": "Dockerfile",
        "dockerfilePath": "apps/api/Dockerfile",
        "context": "."
      },
      "deploy": {
        "startCommand": "npx prisma migrate deploy && node dist/main.js",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      },
      "env": {
        "NODE_ENV": "production",
        "PORT": "3000",
        "TZ": "Asia/Shanghai",
        "CORS_ORIGIN": "https://innerquest.tk",
        "JWT_ACCESS_TTL": "2h",
        "JWT_REFRESH_TTL": "30d",
        "LLM_PROVIDER_ENABLED": "true",
        "LLM_MODEL": "deepseek-chat",
        "LLM_BASE_URL": "https://api.deepseek.com/v1"
      }
    },
    "oxygent": {
      "name": "innerquest-oxygent",
      "build": {
        "builder": "Dockerfile",
        "dockerfilePath": "apps/oxygent/Dockerfile",
        "context": "apps/oxygent"
      },
      "deploy": {
        "startCommand": "uvicorn main:app --host 0.0.0.0 --port 8001",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      },
      "env": {
        "PORT": "8001",
        "TZ": "Asia/Shanghai",
        "DEFAULT_LLM_MODEL_NAME": "deepseek-chat"
      }
    }
  }
}
