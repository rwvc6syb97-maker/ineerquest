{
  "name": "innerquest",
  "version": "1.0.0",
  "private": true,
  "description": "InnerQuest 向内求索 — 基于 AI 的 MBTI 职业规划与辅导平台（monorepo）",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace apps/api run start:dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build:api": "npm --workspace apps/api run build",
    "build:web": "npm --workspace apps/web run build",
    "start:api": "npm --workspace apps/api run start",
    "lint": "npm --workspaces --if-present run lint"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "pdfkit": "^0.19.1"
  }
}
