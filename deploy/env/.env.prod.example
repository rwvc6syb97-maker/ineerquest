# InnerQuest 环境配置样例 —— prod（生产）
# ⚠️ 全部敏感项 [blocked]：必须由 K8s Secret / 云 KMS / Vault 注入，严禁明文提交仓库
# ⚠️ 生产 JWT_SECRET 必须为强随机；数据库/中间件使用独立强密码

NODE_ENV=production
PORT=3000

# MySQL（生产库，连接池按容量调优）
DATABASE_URL="mysql://innerquest:CHANGE_ME@mysql-prod:3306/innerquest?connection_limit=30"  # [blocked]

# 缓存/限流/配额/锁已改用 MySQL(cache_kv / cache_zset)，无需 Redis/MongoDB
CLICKHOUSE_URL="http://clickhouse-prod:8123"
CLICKHOUSE_USER="innerquest"
CLICKHOUSE_PASSWORD="CHANGE_ME"   # [blocked]
CLICKHOUSE_DB="innerquest_ops"

# 阿里云 OSS —— [blocked]
OSS_REGION="oss-cn-hangzhou"
OSS_ACCESS_KEY_ID="CHANGE_ME"
OSS_ACCESS_KEY_SECRET="CHANGE_ME"
OSS_BUCKET="innerquest-prod"

# JWT —— [blocked] 强随机密钥
JWT_SECRET="CHANGE_ME"
JWT_ACCESS_TTL="2h"
JWT_REFRESH_TTL="30d"

# LLM 网关 —— [blocked]
LLM_API_KEY="CHANGE_ME"
# 微信支付（正式商户）—— [blocked]
WECHAT_PAY_MCHID="CHANGE_ME"
WECHAT_PAY_API_KEY="CHANGE_ME"
WECHAT_PAY_CERT_SERIAL="CHANGE_ME"