# InnerQuest 环境配置样例 —— staging（预发布）
# 全部敏感项 [blocked]，由 K8s Secret / 密钥管理注入，禁止明文入库

NODE_ENV=production
PORT=3000

# MySQL（预发库）
DATABASE_URL="mysql://innerquest:CHANGE_ME@mysql-staging:3306/innerquest?connection_limit=20"  # [blocked]

# 缓存/限流/配额/锁已改用 MySQL(cache_kv / cache_zset)，无需 Redis/MongoDB
CLICKHOUSE_URL="http://clickhouse-staging:8123"
CLICKHOUSE_USER="default"
CLICKHOUSE_PASSWORD="CHANGE_ME"   # [blocked]
CLICKHOUSE_DB="innerquest_ops"

# OSS —— [blocked]
OSS_REGION="oss-cn-hangzhou"
OSS_ACCESS_KEY_ID="CHANGE_ME"
OSS_ACCESS_KEY_SECRET="CHANGE_ME"
OSS_BUCKET="innerquest-staging"

# JWT —— [blocked] 强随机密钥
JWT_SECRET="CHANGE_ME"
JWT_ACCESS_TTL="2h"
JWT_REFRESH_TTL="30d"

# LLM 网关 —— [blocked]
LLM_API_KEY="CHANGE_ME"
# 微信支付（sandbox/正式按预发策略）—— [blocked]
WECHAT_PAY_MCHID="CHANGE_ME"
WECHAT_PAY_API_KEY="CHANGE_ME"
WECHAT_PAY_CERT_SERIAL="CHANGE_ME"