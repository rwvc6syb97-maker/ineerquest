{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "api": {
      "name": "innerquest-api",
      "build": {
        "builder": "Dockerfile",
        "dockerfilePath": "apps/api/Dockerfile",
        "context": "."
      },
      "deploy": {
        "startCommand": "node dist/main.js",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      },
      "env": {
        "NODE_ENV": "production",
        "PORT": "3000",
        "TZ": "Asia/Shanghai",
        "USE_MOCK_REDIS": "true",
        "CORS_ORIGIN": "https://innerquest.online",
        "JWT_SECRET": "innerquest-production-secret-key-2026",
        "JWT_ACCESS_TTL": "2h",
        "JWT_REFRESH_TTL": "30d",
        "JWT_ACCESS_TTL_SEC": "7200",
        "JWT_REFRESH_TTL_SEC": "2592000",
        "JWT_ADMIN_REFRESH_TTL_SEC": "28800",
        "LLM_PROVIDER_ENABLED": "true",
        "LLM_API_KEY": "08809cc8813148fe8e1601eedefc1f51",
        "LLM_MODEL": "deepseek-chat",
        "LLM_BASE_URL": "https://autobots.jd.com/chat/148032?version=5b1922dfa53a40e9816a24b744c5ea0e",
        "LLM_API_URL": "https://autobots.jd.com/chat/148032?version=5b1922dfa53a40e9816a24b744c5ea0e",
        "OXYGENT_ENABLED": "false",
        "DEFAULT_LLM_API_KEY": "08809cc8813148fe8e1601eedefc1f51",
        "DEFAULT_LLM_BASE_URL": "https://autobots.jd.com/chat/148032?version=5b1922dfa53a40e9816a24b744c5ea0e",
        "DEFAULT_LLM_MODEL_NAME": "deepseek-chat",
        "SMS_PROVIDER_ENABLED": "false",
        "WECHAT_OAUTH_ENABLED": "false",
        "MONGODB_URI": "",
        "MONGODB_DB": "innerquest",
        "CLICKHOUSE_URL": "",
        "CLICKHOUSE_USER": "default",
        "CLICKHOUSE_PASSWORD": "",
        "CLICKHOUSE_DB": "innerquest_ops",
        "OSS_REGION": "oss-cn-hangzhou",
        "OSS_ACCESS_KEY_ID": "",
        "OSS_ACCESS_KEY_SECRET": "",
        "OSS_BUCKET": "innerquest"
      }
    }
  }
}
