# InnerQuest API 环境变量示例（复制为 .env 后填入真实值）
# 阶段 0 脚手架：以下外部实连凭证均为占位，真实连接标记 blocked

# 服务
PORT=3000
NODE_ENV=development

# MySQL 8.0（Prisma DATABASE_URL）
DATABASE_URL="mysql://root:password@localhost:3306/innerquest?connection_limit=10"

# Redis（缓存 / 限流 / 配额 / 分布式锁）
REDIS_URL="redis://localhost:6379/0"

# MongoDB（AI 消息 / 报告大文本等文档存储）
MONGODB_URI="mongodb://localhost:27017"
MONGODB_DB="innerquest"

# ClickHouse（埋点事件日志分析）
CLICKHOUSE_URL="http://localhost:8123"
CLICKHOUSE_USER="default"
CLICKHOUSE_PASSWORD=""
CLICKHOUSE_DB="innerquest_ops"

# 阿里云 OSS（文件上传）
OSS_REGION="oss-cn-hangzhou"
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
OSS_BUCKET="innerquest"

# JWT / 鉴权
JWT_SECRET="change-me-in-production"
JWT_ACCESS_TTL="2h"
JWT_REFRESH_TTL="30d"
# 认证链实际读取（秒）：access 2h / refresh 30d
JWT_ACCESS_TTL_SEC="7200"
JWT_REFRESH_TTL_SEC="2592000"
JWT_ADMIN_REFRESH_TTL_SEC="28800"

# 外部资质开关（未就位时保持 false，走 mock；blocked）
SMS_PROVIDER_ENABLED="false"
WECHAT_OAUTH_ENABLED="false"

# LLM 网关（统一出口）
LLM_PROVIDER_ENABLED="false"
LLM_API_KEY="CHANGE_ME"
LLM_BASE_URL="CHANGE_ME"
LLM_MODEL="deepseek-chat"

# OxyGent 多智能体服务（通过 Python 微服务调用）
OXYGENT_ENABLED="false"
OXYGENT_URL="http://localhost:8001"